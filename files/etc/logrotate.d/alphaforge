/var/log/alphaforge/audit.jsonl {
    daily
    maxsize 100M
    rotate 14
    compress
    delaycompress
    dateext
    dateformat -%Y%m%d-%H%M%S
    missingok
    notifempty
    copytruncate
}

/var/log/alphaforge/trade.jsonl {
    daily
    maxsize 20M
    rotate 90
    compress
    delaycompress
    dateext
    dateformat -%Y%m%d-%H%M%S
    missingok
    notifempty
    copytruncate
}

/var/log/alphaforge/service.log {
    daily
    maxsize 20M
    rotate 30
    compress
    delaycompress
    dateext
    dateformat -%Y%m%d-%H%M%S
    missingok
    notifempty
    copytruncate
}
