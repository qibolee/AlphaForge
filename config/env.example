# 复制为 config/env 并填真实值（start.sh 首次运行会自动复制）。
# config/env 已被 .gitignore 排除，绝不会提交到 GitHub。
IB_USERNAME=
IB_PASSWORD=
IB_MODE=paper
IB_ACCOUNT=
LIVE_TRADING_ENABLED=false
# 供 IB Gateway 容器使用（Python 引擎不读取该项）。
AUTO_RESTART_TIME=23:45
# 可选：Server酱告警（推送到微信；留空则不告警）。
# 微信扫码登录 https://sct.ftqq.com 拿 SendKey（形如 SCTxxxxxxxx），填到下面。
SERVERCHAN_SENDKEY=
